datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum ScanType {
  FOOTPRINT
  METADATA
  BREACH
  FACE
  RECURSIVE
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  scans         Scan[]
  cleaningTasks CleaningTask[]
  auditLogs     AuditLog[]
}

model Scan {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  target    String // e.g., name, username, email, filename
  type      ScanType
  riskScore Int // 0 to 100
  findings  Finding[]
  createdAt DateTime  @default(now())
}

model Finding {
  id          String   @id @default(uuid())
  scanId      String
  scan        Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  category    String // e.g., Username Found, GPS Exposed, Data Breach, Face Match
  severity    String // HIGH, MEDIUM, LOW, INFO
  title       String
  description String
  remediation String
  rawJson     String? // Saved detailed data (JSON stringified)
  createdAt   DateTime @default(now())
}

model CleaningTask {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String // e.g., "Request erasure under India DPDP Act"
  category    String // Data Broker, Account Deletion, Password Reset, Face Opt-Out
  details     String?
  optOutUrl   String?
  isCompleted Boolean   @default(false)
  sentDate    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String // e.g., USER_LOGIN, ACCOUNT_DELETION, EXPORT_DATA
  details   String?
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
