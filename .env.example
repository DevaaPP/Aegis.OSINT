# Backend Service Port
PORT=5000

# PostgreSQL Database Connection
# If running via Docker: postgresql://postgres:postgres@db:5432/privacy_db?schema=public
# If running locally: postgresql://postgres:postgres@localhost:5432/privacy_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/privacy_db?schema=public"

# Authentication Secrets
JWT_SECRET="super_secret_jwt_signkey_for_digital_footprint_analyzer_2026"
JWT_EXPIRES_IN="7d"

# Client Application URL (For CORS Settings)
FRONTEND_URL="http://localhost:3000"

# Optional External API Keys for Enhanced OSINT Analysis
# If missing, the application runs fully offline with realistic simulators
GEMINI_API_KEY=""
FACECHECK_API_KEY=""
